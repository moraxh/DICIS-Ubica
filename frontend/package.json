{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "cd .. && husky",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "lucide-react": "^0.577.0",
    "motion": "^12.38.0",
    "next": "16.2.0",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "lint-staged": {
    "**/*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc,css}": [
      "biome check --write --no-errors-on-unmatched"
    ],
    "../scripts/**/*.py": [
      "bash -c 'if [ -x ../scripts/.venv/bin/ruff ]; then ../scripts/.venv/bin/ruff check --fix \"$@\"; else echo \"Ruff not found in venv, skipping check\"; fi' _",
      "bash -c 'if [ -x ../scripts/.venv/bin/ruff ]; then ../scripts/.venv/bin/ruff format \"$@\"; else echo \"Ruff not found in venv, skipping format\"; fi' _"
    ]
  }
}
